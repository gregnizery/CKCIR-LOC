# URL de connexion PostgreSQL (fournie automatiquement par Railway quand
# vous attachez un plugin PostgreSQL au service)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Mot de passe d'acces a l'espace staff (/admin)
ADMIN_PASSWORD=change-moi

# Cle utilisee pour signer le cookie de session admin
SESSION_SECRET=change-moi-aussi

# production sur Railway, development en local
NODE_ENV=development

# Port d'ecoute (Railway l'injecte automatiquement, 3000 par defaut en local)
PORT=3000

# URL du pack Chromium pre-compile utilise par @sparticuz/chromium-min
# pour generer les PDF sur Railway (voir README.md, section Deploiement,
# pour la procedure de mise a jour de cette URL).
CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar

# (optionnel, developpement local uniquement) chemin vers un Chrome/Chromium
# deja installe sur la machine, pour eviter de telecharger le pack distant
# a chaque demarrage local. Ex: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE_PATH=
